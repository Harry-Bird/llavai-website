# Llavai Instagram publisher — copy to `.env` and fill in. NEVER commit `.env`.
# See README.md in this folder for how to obtain each value.

# Your Instagram professional account's user id (a long number).
# Get it from the Meta app "API setup with Instagram login" page, or:
#   curl "https://graph.instagram.com/v25.0/me?fields=user_id,username&access_token=TOKEN"
IG_USER_ID=

# Long-lived access token (~60 days). Refresh it with: node ig-publish.js --refresh-token
IG_ACCESS_TOKEN=

# Defaults match the Instagram Login flow. Only change if you used Facebook Login
# (then: GRAPH_HOST=graph.facebook.com and supply a Page-linked IG Business id).
GRAPH_HOST=graph.instagram.com
GRAPH_VERSION=v25.0
